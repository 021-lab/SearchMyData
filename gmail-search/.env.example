# Gmail accounts to search (comma-separated names)
GMAIL_ACCOUNTS=work,personal

# Credentials file per account (OAuth2 JSON from GCP Console)
GMAIL_ACCOUNT_WORK_CREDS=/run/secrets/gmail_work_creds.json
GMAIL_ACCOUNT_PERSONAL_CREDS=/run/secrets/gmail_personal_creds.json

# Optional: custom user ID per account (default: "me")
# GMAIL_ACCOUNT_WORK_USER=me
# GMAIL_ACCOUNT_PERSONAL_USER=me
